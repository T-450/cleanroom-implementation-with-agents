{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cleanroom.example/schemas/tool-policy/v1",
  "title": "Tool Policy",
  "description": "Role-based access control for the file-level legal firewall, consumed by hooks/firewall.py (PreToolUse). Each rule grants or denies a subagent role the use of a tool against a path pattern. Rules are evaluated in order; first match wins; default is 'deny'.",
  "version": "1.0.0",
  "type": "object",
  "required": ["policy_version", "default", "rules", "roles"],
  "additionalProperties": false,
  "properties": {
    "policy_version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "default": {"type": "string", "enum": ["allow", "deny"]},
    "roles": {
      "type": "object",
      "additionalProperties": false,
      "description": "Maps subagent name to its role for policy lookup.",
      "patternProperties": {
        "^[a-z][a-z0-9_-]+$": {
          "type": "string",
          "enum": ["coordinator", "observation", "implementation", "verification"]
        }
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "effect", "roles", "tools"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "pattern": "^R-[a-z0-9-]+$"},
          "description": {"type": "string"},
          "effect": {"type": "string", "enum": ["allow", "deny"]},
          "roles": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "enum": ["coordinator", "observation", "implementation", "verification", "*"]}
          },
          "tools": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "description": "Tool name. '*' matches all. 'Bash:redis-cli:*' matches any redis-cli invocation."
            }
          },
          "path_patterns": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Glob patterns evaluated against the tool's primary path argument (Read.file_path, Write.file_path, Bash cwd, etc.). Omitted means 'any path'."
          },
          "rationale": {"type": "string"}
        }
      }
    }
  }
}
