{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cleanroom.example/schemas/cost-ledger/v1",
  "title": "Cost Ledger",
  "description": "Per-session token and dollar accounting consumed by hooks/cost_cap.py. The ledger is mutated atomically (file lock) by the audit_logger sidecar; cost_cap reads it before each PreToolUse and refuses when remaining_usd < estimated_cost_usd.",
  "version": "1.0.0",
  "type": "object",
  "required": ["session_id", "started_at", "budget_usd", "spent_usd", "events"],
  "additionalProperties": false,
  "properties": {
    "session_id": {"type": "string"},
    "started_at": {"type": "string", "format": "date-time"},
    "budget_usd": {"type": "number", "minimum": 0, "description": "Hard cap. When exceeded, cost_cap.py refuses further tool calls."},
    "spent_usd": {"type": "number", "minimum": 0},
    "remaining_usd": {"type": "number"},
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["event_id", "agent_name", "tool", "input_tokens", "output_tokens", "cost_usd", "timestamp"],
        "additionalProperties": false,
        "properties": {
          "event_id": {"type": "string", "pattern": "^evt-[0-9a-f]{16}$"},
          "agent_name": {"type": "string"},
          "tool": {"type": "string"},
          "model": {"type": "string"},
          "input_tokens": {"type": "integer", "minimum": 0},
          "output_tokens": {"type": "integer", "minimum": 0},
          "cache_read_tokens": {"type": "integer", "minimum": 0},
          "cost_usd": {"type": "number", "minimum": 0},
          "timestamp": {"type": "string", "format": "date-time"}
        }
      }
    },
    "denials": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["timestamp", "agent_name", "estimated_cost_usd"],
        "additionalProperties": false,
        "properties": {
          "timestamp": {"type": "string", "format": "date-time"},
          "agent_name": {"type": "string"},
          "tool": {"type": "string"},
          "estimated_cost_usd": {"type": "number"},
          "remaining_usd_at_denial": {"type": "number"}
        }
      }
    }
  }
}
